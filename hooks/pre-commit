#!/bin/bash
# Pre-commit hook to check formatting, clippy, docs, and tests

set -e

echo "Checking for assert! outside tests..."
found_assert=0
for file in src/*.rs; do
    awk '
        /^#\[cfg\(test\)\]/ { in_test = 1 }
        /^\/\/.*assert/ { next }
        !in_test && /[^a-z_]assert(_eq|_ne)?!|^assert(_eq|_ne)?!/ {
            printf "%s:%d: %s\n", FILENAME, NR, $0
            found = 1
        }
        END { exit found ? 1 : 0 }
    ' "$file" && continue
    found_assert=1
done
if [ "$found_assert" -eq 1 ]; then
    echo "Found assert! macros outside test code. Use Result/Option instead."
    exit 1
fi

echo "Running cargo fmt check..."
if ! cargo fmt --all -- --check; then
    echo "Code is not formatted. Run 'cargo fmt --all' to fix."
    exit 1
fi

echo "Running cargo clippy..."
if ! cargo clippy --all-targets --message-format=short -- -D warnings; then
    echo "Clippy found warnings. Fix them before committing."
    exit 1
fi

echo "Checking documentation coverage..."
if ! doc_output=$(RUSTDOCFLAGS="-D missing_docs -D rustdoc::broken_intra_doc_links" cargo doc --no-deps 2>&1); then
    echo "$doc_output" | grep '^error' | head -20
    echo "Documentation errors. Run: RUSTDOCFLAGS='-D missing_docs -D rustdoc::broken_intra_doc_links' cargo doc --no-deps"
    exit 1
fi

echo "Running tests..."
if ! test_output=$(cargo test 2>&1); then
    echo "$test_output" | tail
    echo "Tests failed. Fix them before committing."
    exit 1
fi

if command -v gitleaks &>/dev/null; then
    echo "Running gitleaks..."
    if ! gitleaks protect --staged --no-banner; then
        echo "gitleaks found secrets in staged changes."
        exit 1
    fi
fi

echo "Pre-commit checks passed"
